# Notion integration token — from https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxx

# ID of your Notion database (the long hex string in the database URL)
# e.g. https://notion.so/yourworkspace/abc123...?v=... → abc123...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your local timezone (IANA format) — used to determine "today" for completed task filtering
# Examples: Asia/Singapore, America/New_York, Europe/London, Australia/Sydney
TIMEZONE=Asia/Singapore
